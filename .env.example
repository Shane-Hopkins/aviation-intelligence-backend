# Copy to .env and fill in values

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/aviation_intelligence

# Anthropic API key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# API server port (frontend expects 3001)
PORT=3001

# Scraper interval in minutes (default: 15)
SCRAPE_INTERVAL_MINUTES=15

# Reddit app credentials (optional — unauthenticated works but has lower rate limits)
# Register at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=AviationIntelligence/1.0
